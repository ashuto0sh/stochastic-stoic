---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTopics } from "../../lib/notes";

const topics = await getTopics();
---

<BaseLayout
  title="Notes — Stochastic Stoic"
  description="Working notes on things I'm learning, organized by topic."
>
  <header class="archive-header">
    <h1>Notes</h1>
    <p class="post-meta">Working notes on things I'm learning, by topic.</p>
  </header>
  <ul class="post-list">
    {
      topics.map((topic) => (
        <li>
          <h3>
            <a href={`/notes/${topic.slug}/`}>{topic.title}</a>
          </h3>
          <p class="post-meta">
            {topic.notes.length} {topic.notes.length === 1 ? "note" : "notes"}
          </p>
          {topic.description && <p>{topic.description}</p>}
        </li>
      ))
    }
  </ul>
</BaseLayout>
