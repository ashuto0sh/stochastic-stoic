---
import { render } from "astro:content";
import NoteLayout from "../../layouts/NoteLayout.astro";
import { getConceptNotes, getTopics, topicOf } from "../../lib/notes";

export async function getStaticPaths() {
  const [notes, topics] = await Promise.all([getConceptNotes(), getTopics()]);
  const topicTitles = new Map(topics.map((t) => [t.slug, t.title]));
  return notes.map((note) => ({
    params: { slug: note.id },
    props: {
      note,
      topic: {
        slug: topicOf(note),
        title: topicTitles.get(topicOf(note)) ?? topicOf(note),
      },
    },
  }));
}

const { note, topic } = Astro.props;
const { Content } = await render(note);
---

<NoteLayout
  title={note.data.title}
  description={note.data.description}
  tags={note.data.tags}
  created={note.data.created}
  topic={topic}
  searchIndex
>
  <Content />
</NoteLayout>
