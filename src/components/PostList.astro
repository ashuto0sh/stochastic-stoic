---
import { render } from "astro:content";
import { CATEGORY_LABELS, formatDate, type Post } from "../lib/posts";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

const items = await Promise.all(
  posts.map(async (post) => ({
    post,
    minutesRead: (await render(post)).remarkPluginFrontmatter
      .minutesRead as number,
  })),
);
---

<ul class="post-list">
  {
    items.map(({ post, minutesRead }) => (
      <li>
        <h3>
          <a href={`/posts/${post.id}/`}>{post.data.title}</a>
        </h3>
        <p class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          {" · "}
          <a href={`/categories/${post.data.category}/`}>
            {CATEGORY_LABELS[post.data.category]}
          </a>
          {` · ${minutesRead} min read`}
          {post.data.draft && <span class="draft-badge">draft</span>}
        </p>
        <p>{post.data.description}</p>
      </li>
    ))
  }
</ul>
